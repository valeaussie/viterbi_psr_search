#------- Path to the input time-series data file (heterodyned or raw filterbank time series)
infile = "/fred/oz022/vdimarco/software/install/viterbi_psr_search/code/experiments/exp_01_first_test/data/J0000-00_cfbf00000_Plan1_1_DM85.60.dat"

#-------# Sampling time of the input time series (seconds per sample)
tsamp = 153e-6

#------- Duration of each Short Fourier Transform (SFT) segment in seconds
#------- This controls the frequency resolution: df ≈ 1/Tsft
Tsft = 5

#------- Number of SFT segments to compute
##------- If set to -1, the code automatically uses the maximum number
#-------# that fits in the data (floor(total_duration / Tsft))
Nsft = -1

#------- Central frequency of the search band (Hz)
#------- The heterodyne and SFT will be centred around this value
f0 = 150

#------- Total bandwidth of the search (Hz)
#------- The code searches from (f0 - bw/2) to (f0 + bw/2)
bw = 150

#------- Zero-padding factor applied before the FFT
#------- padding_factor = 1 → no padding
#------- padding_factor > 1 increases frequency resolution of the FFT
padding_factor = 1

#------- Prefix used for all output files generated by the run
out_prefix = "exp_01_first_test"

#------- Whether to plot the Viterbi frequency path after the search
plot_path = True

#------- Number of highest-likelihood Viterbi paths to return
#------- Usually 1 for the single best track
top_paths = 1

#------- Whether to save the full Viterbi delta matrix to disk
#------- (can be large, so usually False unless debugging)
save_delta = False

#------- Number of harmonics of the signal to include in the search
#------- 1 = fundamental only
#------- >1 = combine multiple harmonics to increase sensitivity
num_harm = 1